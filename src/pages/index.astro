>
  <Nav brand={SITE.brand} />
  <main class="page">
    <Hero />
    <About />
    <Now />
    <Work />
    <Consultancy />
    <Testimonials />
    <Writing />
    <Contact />
  </main>
  <Footer />
</Base>
